{
  "name": "@yetric/audioplayer",
  "version": "0.0.0",
  "description": "Headless TypeScript audio player library for modern browsers.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "react": ["./dist/react.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "website"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "dev": "tsup --watch",
    "demo:start": "vite demo",
    "demo:build": "vite build demo",
    "demo:preview": "vite preview demo",
    "docs:start": "npm run start --workspace website",
    "docs:build": "npm run build --workspace website",
    "docs:serve": "npm run serve --workspace website",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "audio",
    "player",
    "podcast",
    "typescript",
    "browser"
  ],
  "author": "Yetric AB",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yetric/audioplayer.git"
  },
  "homepage": "https://github.com/yetric/audioplayer#readme",
  "bugs": {
    "url": "https://github.com/yetric/audioplayer/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
